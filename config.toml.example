[server]
host = "127.0.0.1"
port = 3000
cors_origins = ["*"]

[modbus]
device = "/dev/ttyUSB0"  # Use "COM3" on Windows
baud_rate = 115200       # 115200 or 3000000 (3 Mbps for continuous streaming)
slave_id = 1
timeout_ms = 5000
retry_attempts = 3

[streaming]
max_connections = 10
buffer_size = 1024
metrics_update_rate_hz = 5.0
raw_data_max_samples = 123
websocket_ping_interval_sec = 30

[logging]
level = "info"
format = "pretty"
